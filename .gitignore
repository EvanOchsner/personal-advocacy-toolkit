# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
dist/
build/

# Editors / OS
.DS_Store
.idea/
.vscode/
*.swp

# Scratch
.tmp/

# Benchmark baseline — regenerated by tests/extraction/test_benchmark.py
# every run; useful for local diffs but not stable across machines.
tests/extraction/.benchmark-baseline.json

# Case-map dashboard cache. Per-case precompute output from
# `scripts.case_map_build`; regenerated on demand and never committed.
.case-map/

# Local settings (never published)
.env
.env.local

# Claude Code local state. Skills (.claude/skills/) and the repo-level
# CLAUDE.md ARE committed — that's how the BYOA workflow ships. But
# session-local planning notes and per-machine settings are not.
.claude/plans/
.claude/settings.local.json
.claude/worktrees/
.claude/scheduled_tasks.lock

# wrangler files
.wrangler
.dev.vars*
!.dev.vars.example
!.env.example
