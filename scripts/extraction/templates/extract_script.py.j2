#!/usr/bin/env python3
"""Reproducibility script for ``{{ source_file }}``.

Generated by scripts/extraction/recipe.py on {{ generated_at }}.

Re-runs the exact extraction recipe — same tier, same provider, same
overrides — that produced ``{{ structured_path }}`` and
``{{ readable_path }}``. The script asserts the new outputs are
byte-identical to what's currently on disk; non-zero exit means
extraction has drifted from the recorded recipe.

If you intentionally changed the recipe (e.g. added a new
strip_text_pattern), regenerate this script with::

    uv run python -m scripts.extraction \\
        --case-root {{ case_root }} \\
        --file {{ source_file }} \\
        --emit-recipe
"""
from __future__ import annotations

import hashlib
import json
import sys
from pathlib import Path

# RECIPE — do not edit by hand. Regenerate with the command in the
# docstring above. Stored as a JSON string + parsed at import time so
# JSON's lowercase ``true`` / ``false`` / ``null`` work without
# Python interpolation tricks.
RECIPE = json.loads(r"""
{{ recipe_json }}
""")


def _sha256(p: Path) -> str:
    return hashlib.sha256(p.read_bytes()).hexdigest()


def main() -> int:
    case_root = Path(RECIPE["case_root"])
    source = case_root / RECIPE["source_file_relative"]
    expected = RECIPE["expected"]

    if not source.exists():
        print(f"  ERROR: source missing: {source}", file=sys.stderr)
        return 2
    actual_source_sha = _sha256(source)
    if actual_source_sha != expected["source_sha256"]:
        print(
            f"  ERROR: source SHA256 mismatch — recipe was recorded against "
            f"a different bytes set.\n"
            f"    recorded: {expected['source_sha256']}\n"
            f"    on disk:  {actual_source_sha}",
            file=sys.stderr,
        )
        return 3

    # Re-run the cascade.
    from scripts.extraction import cascade

    result = cascade.extract(
        source,
        case_root=case_root,
        vlm_provider=RECIPE.get("vlm_provider"),
        interactive=False,
        verbose=False,
    )

    structured_path = case_root / RECIPE["structured_path_relative"]
    readable_path = case_root / RECIPE["readable_path_relative"]

    # Compare structured JSON.
    new_struct = json.dumps(result.to_metadata_dict(), indent=2, sort_keys=True)
    on_disk_struct = structured_path.read_text(encoding="utf-8") if structured_path.exists() else ""
    if new_struct != on_disk_struct:
        print(
            f"  WARN: structured sidecar differs from recipe replay.\n"
            f"    on disk: {structured_path}",
            file=sys.stderr,
        )
        # Allowed: structured carries timestamps that legitimately
        # change between runs. Warn but don't fail on this alone.

    # Compare readable text — this *must* match.
    on_disk_text = readable_path.read_text(encoding="utf-8") if readable_path.exists() else ""
    if result.text != on_disk_text:
        print(
            f"  ERROR: readable text differs from recipe replay.\n"
            f"    on disk: {readable_path}\n"
            f"    Diff (first 200 chars on each side):\n"
            f"      on disk: {on_disk_text[:200]!r}\n"
            f"      replay:  {result.text[:200]!r}",
            file=sys.stderr,
        )
        return 4

    print(f"  OK  {source} -> {readable_path} (recipe reproduces byte-identical text)")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
